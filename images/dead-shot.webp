<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 200 200" width="200" height="200">
  <!-- Background circle -->
  <circle cx="100" cy="100" r="95" fill="#1E90FF" stroke="#FFD700" stroke-width="4"/>
  
  <!-- Cannon base -->
  <ellipse cx="50" cy="140" rx="25" ry="15" fill="#8B4513"/>
  <circle cx="50" cy="135" r="20" fill="#2C2C2C"/>
  
  <!-- Cannon barrel -->
  <rect x="50" y="115" width="60" height="18" rx="3" fill="#2C2C2C" transform="rotate(-35 50 125)"/>
  
  <!-- Cannonball in flight -->
  <circle cx="130" cy="80" r="12" fill="#1A1A1A" stroke="#000" stroke-width="2"/>
  
  <!-- Motion lines -->
  <line x1="115" y1="85" x2="105" y2="90" stroke="#fff" stroke-width="3" stroke-linecap="round" opacity="0.6"/>
  <line x1="110" y1="75" x2="100" y2="78" stroke="#fff" stroke-width="3" stroke-linecap="round" opacity="0.6"/>
  <line x1="120" y1="70" x2="110" y2="72" stroke="#fff" stroke-width="3" stroke-linecap="round" opacity="0.6"/>
  
  <!-- Pirate (target) -->
  <circle cx="155" cy="120" r="18" fill="#FFE4B5" stroke="#000" stroke-width="2"/>
  
  <!-- Pirate hat -->
  <path d="M 135 105 L 155 90 L 175 105 Z" fill="#000" stroke="#000" stroke-width="2"/>
  
  <!-- Pirate eyes -->
  <circle cx="150" cy="118" r="2.5" fill="#000"/>
  <circle cx="160" cy="118" r="2.5" fill="#000"/>
  
  <!-- Explosion effect behind pirate -->
  <circle cx="155" cy="120" r="25" fill="#FF6600" opacity="0.3"/>
  <circle cx="155" cy="120" r="18" fill="#FFD700" opacity="0.4"/>
  
  <!-- Wooden crate -->
  <rect x="140" y="140" width="30" height="30" fill="#A0522D" stroke="#8B4513" stroke-width="2"/>
  <line x1="145" y1="140" x2="145" y2="170" stroke="#8B4513" stroke-width="2"/>
  <line x1="165" y1="140" x2="165" y2="170" stroke="#8B4513" stroke-width="2"/>
  <line x1="140" y1="150" x2="170" y2="150" stroke="#8B4513" stroke-width="2"/>
  <line x1="140" y1="160" x2="170" y2="160" stroke="#8B4513" stroke-width="2"/>
</svg>
